# Copy to keystore.properties (git-ignored) and fill in to sign release builds.
# Generate a keystore:
#   keytool -genkey -v -keystore fuelradar-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias fuelradar
storeFile=fuelradar-release.jks
storePassword=CHANGE_ME
keyAlias=fuelradar
keyPassword=CHANGE_ME
